<?xml version="1.0" encoding="utf-8"?>
<!--
  启动图标前景:白色圆角播放三角 + 手绘风「GIF」字样(视频 → GIF)。
  内容控制在自适应图标 66dp 安全圆内(中心 54,54、半径 33);
  同时作为 monochrome 层(Android 13+ 主题图标)。
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- 播放三角(fill + 粗 stroke 圆角化)。 -->
    <path
        android:pathData="M44,26 L72,42 L44,58 Z"
        android:fillColor="#FFFFFF"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="6"
        android:strokeLineJoin="round" />
    <!-- G:开口朝右上的圆弧 + 内收横杠。 -->
    <path
        android:pathData="M46,67 A8.5,8.5 0 1 0 48.5,73 L42.5,73"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
    <!-- I -->
    <path
        android:pathData="M56,65.5 L56,80.5"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="5"
        android:strokeLineCap="round" />
    <!-- F -->
    <path
        android:pathData="M64,80.5 L64,65.5 L75,65.5 M64,72.5 L72,72.5"
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
</vector>
